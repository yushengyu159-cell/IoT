# 邮箱验证配置
# 生产环境请修改为真实的邮箱和密码

email:
  # QQ邮箱配置
  qq:
    host: "smtp.qq.com"
    port: "587"
    username: "tj18832045990@qq.com"  # 替换为真实的QQ邮箱
    password: "your-qq-smtp-password"  # 需要配置QQ邮箱的SMTP授权码
    from: "tj18832045990@qq.com"
    enabled: true
    use_ssl: false
    use_tls: true
  
  # 163邮箱配置
  163:
    host: "smtp.163.com"
    port: "465"  # 使用SSL端口
    username: "tj18832045990@163.com"  # 替换为真实的163邮箱
    password: "your-163-smtp-password"  # 需要配置163邮箱的SMTP授权码
    from: "tj18832045990@163.com"
    enabled: true
    use_ssl: true   # 使用SSL连接
    use_tls: false
  
  # Gmail配置
  gmail:
    host: "smtp.gmail.com"
    port: "587"
    username: "your-gmail@gmail.com"  # 替换为真实的Gmail邮箱
    password: "your-gmail-app-password"  # 需要配置Gmail应用专用密码
    from: "your-gmail@gmail.com"
    enabled: false  # 暂时禁用Gmail
    use_ssl: false
    use_tls: true
  
  # 通用配置
  common:
    # 验证码有效期（分钟）
    code_expire_minutes: 10
    # 重新发送冷却期（秒）
    resend_cooldown_seconds: 60
    # 最大发送次数（防止滥用）
    max_send_per_hour: 10
    # 邮件模板
    subject: "ESG VISA - 邮箱验证码"
    # 是否在开发环境显示验证码
    show_code_in_dev: true
