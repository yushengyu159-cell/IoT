						},
						{
							"key": "desc",
							"value": "测试PDF文件上传 - Postman自动化测试",
							"type": "text",
							"description": "文件描述"
						},
						{
							"key": "uploader",
							"value": "18027473816@163.com",
							"type": "text",
							"description": "上传者账号"
						}
					]
				},
				"url": {
					"raw": "https://app.esgvisa.com/api/esg/upload-encrypted",
					"protocol": "https",
					"host": [
						"app",
						"esgvisa",
						"com"
					],
					"path": [
						"api",
						"esg",
						"upload-encrypted"
					]
				},
				"description": "正常上传PDF文件测试用例\n\n**测试步骤:**\n1. 选择一个PDF文件\n2. 填写文件描述\n3. 使用测试账号上传\n\n**预期结果:**\n- HTTP状态码: 200\n- 业务状态码: 200\n- 返回文件CID和加密密钥\n- 返回完整的文件元数据"
			},
			"response": []
