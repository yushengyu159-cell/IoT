{
	"info": {
		"_postman_id": "esg-file-upload-001",
		"name": "ESG文件上传接口测试集合",
		"description": "ESG文件上传接口测试集合\n\n测试接口: POST https://app.esgvisa.com/api/esg/upload-encrypted\n测试账号: 18027473816@163.com\n\n包含以下测试用例:\n1. 正常上传PDF文件\n2. 上传图片文件\n3. 上传大文件\n4. 缺少文件参数测试\n5. 仅上传文件（无描述）\n6. 查询文件详情\n7. 下载加密文件",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "esg-visa-api"
	},
	"item": [
		{
			"name": "1. 正常上传PDF文件",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"HTTP状态码为200\", function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"业务状态码为200\", function() {",
							"    const responseBody = pm.response.json();",
							"    pm.expect(responseBody.code).to.eql(200);",
							"});",
							"",
							"pm.test(\"返回文件CID\", function() {",
							"    const responseBody = pm.response.json();",
							"    pm.expect(responseBody.data.meta.cids).to.be.an('array');",
							"    pm.expect(responseBody.data.meta.cids.length).to.be.greaterThan(0);",
							"    ",
							"    // 保存CID到环境变量",
							"    if (responseBody.data.meta.cids && responseBody.data.meta.cids.length > 0) {",
							"        pm.environment.set(\"file_cid\", responseBody.data.meta.cids[0]);",
							"    }",
							"});",
							"",
							"pm.test(\"返回加密密钥\", function() {",
							"    const responseBody = pm.response.json();",
							"    pm.expect(responseBody.data.key).to.not.be.null;",
							"    pm.expect(responseBody.data.key).to.not.be.empty;",
							"    ",
							"    // 保存密钥到环境变量",
							"    if (responseBody.data.key) {",
							"        pm.environment.set(\"file_key\", responseBody.data.key);",
							"    }",
							"});",
							"",
							"pm.test(\"返回文件元数据\", function() {",
							"    const responseBody = pm.response.json();",
							"    pm.expect(responseBody.data.meta.fileName).to.not.be.null;",
							"    pm.expect(responseBody.data.meta.fileSize).to.be.a('number');",
							"    pm.expect(responseBody.data.meta.uploadAt).to.not.be.null;",
							"});",
							"",
							"pm.test(\"返回分片信息\", function() {",
							"    const responseBody = pm.response.json();",
							"    pm.expect(responseBody.data.chunkCount).to.be.a('number');",
							"    pm.expect(responseBody.data.chunkCount).to.be.greaterThan(0);",
							"});",
							"",
							"pm.test(\"返回时间统计\", function() {",
							"    const responseBody = pm.response.json();",
							"    pm.expect(responseBody.data.timeStats).to.not.be.null;",
							"    pm.expect(responseBody.data.timeStats.totalTime).to.not.be.null;",
							"});",
							"",
							"// 打印关键信息",
							"const responseBody = pm.response.json();",
							"if (responseBody.code === 200) {",
							"    console.log(\"✅ 上传成功!\");",
							"    console.log(\"文件CID:\", responseBody.data.meta.cids[0]);",
							"    console.log(\"加密密钥:\", responseBody.data.key);",
							"    console.log(\"文件大小:\", responseBody.data.meta.fileSize, \"字节\");",
							"    console.log(\"分片数量:\", responseBody.data.chunkCount);",
							"    console.log(\"上传耗时:\", responseBody.data.timeStats.totalTime);",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"protocolProfileBehavior": {
				"strictSSL": true
			},
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "file",
							"type": "file",
							"src": [],
