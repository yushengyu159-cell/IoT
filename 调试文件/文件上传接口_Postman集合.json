		{
			"name": "7. 下载加密文件",
			"event": [
				{
					"listen": "prerequest",
					"script": {
						"exec": [
							"// 如果没有设置CID和KEY，使用默认值",
							"if (!pm.environment.get(\"file_cid\")) {",
							"    pm.environment.set(\"file_cid\", \"QmXXX...\");",
							"}",
							"if (!pm.environment.get(\"file_key\")) {",
							"    pm.environment.set(\"file_key\", \"base64_encoded_key\");",
							"}"
						],
						"type": "text/javascript"
					}
				},
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test(\"HTTP状态码为200\", function() {",
							"    pm.response.to.have.status(200);",
							"});",
							"",
							"pm.test(\"返回文件内容\", function() {",
							"    pm.expect(pm.response.headers.get(\"Content-Type\")).to.include(\"application/octet-stream\");",
							"    pm.expect(pm.response.body).to.not.be.empty;",
							"});",
							"",
							"// 打印下载信息",
							"console.log(\"文件大小:\", pm.response.headers.get(\"Content-Length\"), \"字节\");",
							"console.log(\"内容类型:\", pm.response.headers.get(\"Content-Type\"));"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "application/json"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"cid\": \"{{file_cid}}\",\n    \"key\": \"{{file_key}}\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "https://app.esgvisa.com/api/esg/download-encrypted",
