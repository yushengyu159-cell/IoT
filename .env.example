# MySQL数据库配置
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=esg
MYSQL_DSN=${MYSQL_USER}:${MYSQL_PASSWORD}@tcp(${MYSQL_HOST}:${MYSQL_PORT})/${MYSQL_DATABASE}?charset=utf8mb4&parseTime=True&loc=Local

# Fabric配置
FABRIC_CONFIG_PATH=/root/home/go/fabric-samples/test-network

# IPFS配置
IPFS_API=http://127.0.0.1:5001
IPFS_GATEWAY=http://127.0.0.1:8081

# 服务配置
SERVER_PORT=8199
ENV=production

# 日志配置
LOG_LEVEL=info
LOG_MAX_SIZE=100
LOG_MAX_BACKUPS=3
LOG_MAX_AGE=28

# 地图API配置
MAP_AMAP_KEY=your_amap_key
MAP_BAIDU_KEY=your_baidu_key

# 安全配置
SESSION_SECRET=your_session_secret_here_change_this
JWT_SECRET=your_jwt_secret_here_change_this
CSRF_SECRET=your_csrf_secret_here_change_this
